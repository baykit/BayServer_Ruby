# Classes
module Baykit
  module BayServer
    module Util
      class IOUtil
        def self.read_int32: (IO io) -> (Integer | nil)
        def self.write_int32: (IO io, Integer i) -> Integer
        def self.get_sock_recv_buf_size: (IO skt) -> Integer
        def self.get_remote_address: (untyped io) -> [String, Integer]
        def self.get_server_address: (untyped io) -> String
      end
    end
  end
end
